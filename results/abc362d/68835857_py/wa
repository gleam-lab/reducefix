#!/usr/bin/env python3
import heapq
N,M = map(int,input().split())
A = list(map(int,input().split()))
G = [[] for _ in range(N)]
for _ in range(M):
  u,v,b = map(int,input().split())
  u -=1
  v -=1
  G[u].append((v,b+v))
  G[v].append((u,b+u))
INF = 10*18
omosa = [INF]*N
omosa[0] =A[0]
pq = [(A[0],0)]
while pq:
  t,u = heapq.heappop(pq)
  if t > omosa[u]:
    continue
  for v,b in G[u]:
    if omosa[v] > t+b:
      omosa[v] = t+b
      heapq.heappush(pq,(omosa[v],v))
print(*omosa[1:])



