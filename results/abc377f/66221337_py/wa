#!/usr/bin/env python3
N,M = map(int,input().split())
ab = [[*map(int,input().split())] for _ in range(M)]
ab = [(ab[m][1],ab[m][0]) for m in range(M)]
strai, diago = set(), set()
dame = M
for m in range(M):
    a,b = ab[m]
    if (a,0) not in strai : 
        dame+=N-1
        strai.add((a,0))
    if (0,b) not in strai : 
        dame+=N-1
        strai.add((0,b))
    if (1,b-a) not in diago : 
        dame += min(a-1,b-1)+min(N-a,N-b)
        diago.add((1,b-a))
    if (-1,b+a) not in diago : 
        dame += min(N-a,b-1)+min(a-1,N-b)
        diago.add((-1,b+a))
    s = set()
    for bef in range(m):
        aa,bb = ab[bef]
        s.add((a,bb)) # 縦横
        s.add((aa,b)) # 横縦
        s.add((a,-a+(bb+aa))) #縦負
        s.add((a,a+(bb-aa))) #縦正
        s.add((-b+(bb+aa),b)) #横負
        s.add((b-(bb-aa),b)) #横正
        s.add((aa,aa+(b-a))) #正縦
        s.add((aa,-aa+(b+a))) #負縦
        s.add((-bb+(b+a),bb)) #負横
        s.add((bb-(b-a),bb)) #正横
        if (a+b)%2==(aa+bb)%2 : 
            s.add(((b+a-(bb-aa))//2,(b+a+bb-aa)//2)) #負正
            s.add(((bb+aa-(b-a))//2,(bb+aa+b-a)//2)) #正負
    dame -= sum(1 for x,y in s if 1<=x<=N and 1<=y<=N)
print(N**2-dame)