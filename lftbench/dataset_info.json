{
  "dataset_name": "lftbench",
  "version": "1.0.0",
  "description": "LFTBench: A Long-Failure Inducing Test Input Program Repair Benchmark",
  "license": "MIT",
  "features": {
    "problem_id": "string",
    "submission_id": "string",
    "language": "string",
    "wa_code_path": "string",
    "ac_code_path": "string",
    "original_test_input_path": "string",
    "reduced_test_input_path": "string",
    "test_input_summary": "object",
    "repair_strategies": "object"
  },
  "splits": {
    "cpp": {
      "name": "cpp",
      "num_examples": 200,
      "description": "C++ Wrong Answer submissions with ground truth and test inputs"
    },
    "python": {
      "name": "python",
      "num_examples": 20,
      "description": "Python Wrong Answer submissions (using C++ AC as ground truth)"
    }
  },
  "metadata_files": [
    "metadata/cpp_submissions.jsonl",
    "metadata/python_submissions.jsonl",
    "metadata/problems.json",
    "metadata/editorials/"
  ],
  "statistics": {
    "total_problems": 20,
    "total_submissions": 220,
    "cpp_submissions": 200,
    "python_submissions": 20,
    "contest_range": "ABC 361-377",
    "data_completeness": "99%+"
  }
}
